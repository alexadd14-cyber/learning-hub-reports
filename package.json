{
  "name": "learning-hub-reports",
  "version": "0.1.0",
  "private": true,
  "scripts": { 
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "read-pdf": "node scripts/read-pdf.mjs",
    "setup:mcp": "npm install --prefix mcp/pdf-reader",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.16.2",
    "@react-pdf/renderer": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "next": "^15.3.3",
    "next-auth": "^4.24.14",
    "prisma": "^6.16.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3"
  }
}
