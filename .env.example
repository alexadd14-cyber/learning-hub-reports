# Copy this file to .env.local and add your OpenAI API key
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
# Vision model for reading marked test photos (gpt-4o recommended)
OPENAI_VISION_MODEL=gpt-4o

# Demo mode: when not "false", auth + subscriptions are bypassed and no real
# database is used. Set DEMO_MODE=false to restore full login/subscription
# enforcement (requires a working DATABASE_URL below).
DEMO_MODE=true

# Database. In demo mode this is only used so the Prisma client can construct;
# no queries run and no data is stored, so a dummy value is fine.
# When DEMO_MODE=false, point this at a real database (e.g. hosted Postgres).
DATABASE_URL=file:./dev.db

# Authentication (only needed when DEMO_MODE=false)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Stripe (optional now, required when enabling online billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
