# Copy this file to .env.local and add your Ollama API key
# Get a key at https://ollama.com/settings/keys (for cloud models)
OLLAMA_API_KEY=your_api_key_here
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=llama3.2
# Vision model for reading marked test photos (e.g. llava, moondream, gemma3)
OLLAMA_VISION_MODEL=llava

# Authentication and database (for multi-branch subscriptions)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/learning_hub_reports?schema=public
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Stripe (optional now, required when enabling online billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
