# Copy this file to .env.local and add your Ollama API key
# Get a key at https://ollama.com/settings/keys (for cloud models)
OLLAMA_API_KEY=your_api_key_here
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=llama3.2
# Vision model for reading marked test photos (e.g. llava, moondream, gemma3)
OLLAMA_VISION_MODEL=llava
